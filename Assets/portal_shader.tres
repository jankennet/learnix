code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform float colorIntensity;
uniform vec4 portalColor : source_color;
uniform vec2 speedXY;
uniform sampler2D portalTexture : source_color;
uniform sampler2D tex_frg_6 : source_color;



void fragment() {
// FloatParameter:11
	float n_out11p0 = colorIntensity;


// ColorParameter:9
	vec4 n_out9p0 = portalColor;


// VectorOp:12
	vec4 n_out12p0 = vec4(n_out11p0) * n_out9p0;


	vec2 n_out2p0;
// UVPolarCoord:2
	vec2 n_in2p1 = vec2(0.50000, 0.50000);
	float n_in2p2 = 2.00000;
	float n_in2p3 = 1.00000;
	{
		vec2 __dir = UV - n_in2p1;
		float __radius = length(__dir) * 2.0;
		float __angle = atan(__dir.y, __dir.x) * 1.0 / (PI * 2.0);
		n_out2p0 = vec2(__radius * n_in2p2, __angle * n_in2p3);
	}


// Input:4
	float n_out4p0 = TIME;


// Vector2Parameter:13
	vec2 n_out13p0 = speedXY;


// VectorOp:5
	vec2 n_out5p0 = vec2(n_out4p0) * n_out13p0;


// UVFunc:3
	vec2 n_in3p1 = vec2(1.00000, 1.00000);
	vec2 n_out3p0 = n_out5p0 * n_in3p1 + n_out2p0;


	vec4 n_out15p0;
// Texture2D:15
	n_out15p0 = texture(portalTexture, n_out3p0);


// VectorOp:10
	vec4 n_out10p0 = n_out12p0 * n_out15p0;


// Texture2D:6
	vec4 n_out6p0 = texture(tex_frg_6, UV);
	float n_out6p1 = n_out6p0.r;


// Output:0
	ALBEDO = vec3(n_out10p0.xyz);
	ALPHA = n_out6p1;


}
"
