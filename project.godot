; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Learnix"
run/main_scene="res://Scenes/ui/title_menu.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SceneManager="*res://scripts/SceneManager.gd"
InteractionManager="*res://scripts/Interaction_Manager.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
InteractionPrompt="*res://Scenes/ui/interaction_prompt.tscn"
ControlsHelp="*res://Scenes/ui/controls_help.tscn"
PauseMenu="*res://Scenes/ui/pause_menu.tscn"

[dialogue_manager]

runtime/balloon_path="res://Scenes/dialogue_balloon.tscn"
runtime/state_autoload_shortcuts=["SceneManager"]

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/gdUnit4/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")

[global_group]

player=""
spawn_point="these are spawn points in different levels"
npcs="These are the npcs for every level"

