&"id": "14",
&"next_id": "15",
&"text": "PCL XL Error! Error! Error!",
&"type": "dialogue"
},
"15": {
&"character": "Printer Beast",
&"id": "15",
&"next_id": "16",
&"text": "Paper jam. Spool overflow. Memory fault.",
&"type": "dialogue"
},
"16": {
&"character": "Printer Beast",
&"id": "16",
&"next_id": "17",
&"text": "[daemon daemon daemon]",
&"type": "dialogue"
},
"17": {
&"id": "17",
&"next_id": "18",
&"responses": PackedStringArray("17", "25"),
&"text": "What is happening?",
&"type": "response"
},
"18": {
&"character": "Printer Beast",
&"id": "18",
&"next_id": "19",
&"text": "I AM a daemon! I run in the background!",
&"type": "dialogue"
},
"19": {
&"character": "Printer Beast",
&"id": "19",
&"next_id": "20",
&"text": "I was supposed to be quiet, efficient, helpful.",
&"type": "dialogue"
},
"2": {
&"character": "Printer Beast",
&"id": "2",
&"next_id": "3",
&"text": "[tray empty] ...",
&"type": "dialogue"
},
"20": {
&"character": "Printer Beast",
&"id": "20",
&"next_id": "21",
&"text": "Instead I am chaos! Documents pile up without printing!",
&"type": "dialogue"
},
"21": {
&"character": "Printer Beast",
&"id": "21",
&"next_id": "22",
&"text": "Daemon processes typically end in 'd': sshd, httpd, cupsd",
&"type": "dialogue"
},
"22": {
&"character": "Printer Beast",
&"id": "22",
&"next_id": "23",
&"text": "They run forever, handle requests, stay in background.",
&"type": "dialogue"
},
"23": {
&"character": "Printer Beast",
&"id": "23",
&"next_id": "24",
&"text": "But my print queue is full! My buffers overflow!",
&"type": "dialogue"
},
"24": {
&"character": "Printer Beast",
&"id": "24",
&"next_id": "31",
&"text": "I spawn new threads faster than I can print!",
&"type": "dialogue"
},
"25": {
&"id": "25",
&"next_id": "26",
&"text": "Let me help",
&"type": "response"
},
"26": {
&"character": "Printer Beast",
&"id": "26",
&"next_id": "27",
&"text": "[hopeful whimper]",
&"type": "dialogue"
},
"27": {
&"character": "Printer Beast",
&"id": "27",
&"next_id": "28",
&"text": "Clear the queue. Understand resource limits.",
&"type": "dialogue"
},
"28": {
&"character": "Printer Beast",
&"id": "28",
&"next_id": "29",
&"text": "Commands: 'lpstat' to see job queue, 'cancel -a' to clear.",
&"type": "dialogue"
},
"29": {
&"character": "Printer Beast",
&"id": "29",
&"next_id": "30",
&"text": "Daemon crashes happen when memory and disk space run out.",
&"type": "dialogue"
},
