"34": {
&"id": "34",
&"next_id": "35",
&"text": "I will return later.",
&"type": "response"
},
"35": {
&"id": "35",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
"36": {
&"condition": {},
&"id": "36",
&"next_id": "37",
&"next_id_after": "77",
&"type": "condition"
},
"37": {
&"character": "Hardware Ghost",
&"id": "37",
&"next_id": "38",
&"text": "[whisper] Legacy device... no longer recognized.",
&"type": "dialogue"
},
"38": {
&"character": "Hardware Ghost",
&"id": "38",
&"next_id": "39",
&"text": "I am a driver from hardware nobody uses anymore.",
&"type": "dialogue"
},
"39": {
&"character": "Hardware Ghost",
&"id": "39",
&"next_id": "40",
&"text": "Kernel modules that nobody loads. Legacy support nobody values.",
&"type": "dialogue"
},
"4": {
&"character": "Hardware Ghost",
&"id": "4",
&"next_id": "5",
&"text": "The old drivers can finally rest.",
&"type": "dialogue"
},
"40": {
&"character": "Hardware Ghost",
&"id": "40",
&"next_id": "41",
&"text": "I only remember the logs. I only remember the faults.",
&"type": "dialogue"
},
"41": {
&"id": "41",
&"next_id": "42",
&"responses": PackedStringArray("41", "47", "53", "58", "66"),
&"text": "What happened here?",
&"type": "response"
},
"42": {
&"character": "Hardware Ghost",
&"id": "42",
&"next_id": "43",
&"text": "A kernel upgrade. ABI changes. The stack moved on.",
&"type": "dialogue"
},
"43": {
&"character": "Hardware Ghost",
&"id": "43",
&"next_id": "44",
&"text": "My symbols don't match anymore. My interrupts don't fire.",
&"type": "dialogue"
},
"44": {
&"character": "Hardware Ghost",
&"id": "44",
&"next_id": "45",
&"text": "We were left behind, still calling out, still failing.",
&"type": "dialogue"
},
"45": {
&"character": "Hardware Ghost",
&"id": "45",
&"next_id": "46",
&"text": "Drivers live between hardware and the kernel.",
&"type": "dialogue"
},
"46": {
&"character": "Hardware Ghost",
&"id": "46",
&"next_id": "73",
&"text": "When the kernel changes, some drivers die.",
&"type": "dialogue"
},
"47": {
&"id": "47",
&"next_id": "48",
&"text": "What are drivers?",
&"type": "response"
},
"48": {
&"character": "Hardware Ghost",
&"id": "48",
&"next_id": "49",
&"text": "Drivers are translators. Hardware speaks in signals and voltages.",
&"type": "dialogue"
},
"49": {
&"character": "Hardware Ghost",
&"id": "49",
&"next_id": "50",
&"text": "The kernel speaks in system calls and interrupts.",
&"type": "dialogue"
},
"5": {
&"character": "Hardware Ghost",
&"id": "5",
&"next_id": "6",
&"text": "Take this gratitude. It is all I have left.",
&"type": "dialogue"
},
"50": {
&"character": "Hardware Ghost",
&"id": "50",
&"next_id": "51",
&"text": "Drivers translate between them. They load into kernel memory.",
&"type": "dialogue"
},
"51": {
&"character": "Hardware Ghost",
&"id": "51",
&"next_id": "52",
&"text": "They handle hardware events: \"button pressed!\" or \"data ready!\"",
&"type": "dialogue"
},
"52": {
&"character": "Hardware Ghost",
&"id": "52",
&"next_id": "73",
&"text": "Without drivers, hardware is just... silent silicon.",
&"type": "dialogue"
},
"53": {
&"id": "53",
&"next_id": "54",
&"text": "What do you need?",
&"type": "response"
},
"54": {
&"character": "Hardware Ghost",
&"id": "54",
&"next_id": "55",
&"text": "A remnant of old code rages nearby. It tears at the bus.",
&"type": "dialogue"
},
"55": {
&"character": "Hardware Ghost",
&"id": "55",
&"next_id": "56",
&"text": "And the Printer daemon hoards the key to the depths.",
&"type": "dialogue"
},
"56": {
&"character": "Hardware Ghost",
&"id": "56",
&"next_id": "57",
&"text": "Quiet them both, restore order to the logs.",
&"type": "dialogue"
},
"57": {
&"character": "Hardware Ghost",
&"id": "57",
&"next_id": "73",
&"text": "Then the system can rest.",
&"type": "dialogue"
},
"58": {
&"id": "58",
&"next_id": "59",
&"text": "I will help.",
&"type": "response"
},
"59": {
&"character": "Hardware Ghost",
&"id": "59",
&"next_id": "60",
&"text": "Then listen for the error messages. They whisper the problem.",
&"type": "dialogue"
},
