"24": {
&"character": "Hardware Ghost",
&"id": "24",
&"next_id": "25",
&"text": "The remnant still lashes out.",
&"type": "dialogue"
},
"25": {
&"character": "Hardware Ghost",
&"id": "25",
&"next_id": "26",
&"text": "The printer daemon still screams.",
&"type": "dialogue"
},
"26": {
&"character": "Hardware Ghost",
&"id": "26",
&"next_id": "27",
&"text": "Please, end the errors.",
&"type": "dialogue"
},
"27": {
&"id": "27",
&"next_id": "28",
&"responses": PackedStringArray("27", "31", "34"),
&"text": "I will calm the logs. (Puzzle)",
&"type": "response"
},
"28": {
&"character": "Hardware Ghost",
&"id": "28",
&"next_id": "29",
&"text": "Start with ls/cat/scan, then follow the log clues.",
&"type": "dialogue"
},
"29": {
&"id": "29",
