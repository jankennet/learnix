"14": {
&"character": "Hardware Ghost",
&"id": "14",
&"next_id": "15",
&"text": "[flicker] The terminal threw you out.",
&"type": "dialogue"
},
"15": {
&"character": "Hardware Ghost",
&"id": "15",
&"next_id": "16",
&"text": "Too many unstable fixes in one run.",
&"type": "dialogue"
},
"16": {
&"character": "Hardware Ghost",
&"id": "16",
&"next_id": "17",
&"text": "Breathe. Then we can try again.",
&"type": "dialogue"
},
