&"id": "60",
&"next_id": "61",
&"text": "Study the logs. Start with ls/cat/scan. Then isolate the issue.",
&"type": "dialogue"
},
"61": {
&"character": "Hardware Ghost",
&"id": "61",
&"next_id": "62",
&"text": "If you can calm the logs, I can guide you further.",
&"type": "dialogue"
},
