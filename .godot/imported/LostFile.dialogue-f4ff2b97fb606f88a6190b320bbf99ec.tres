"12": {
&"character": "Lost File",
&"id": "12",
&"next_id": "13",
&"text": "[The Lost File scatters, unable to stabilize]",
&"type": "dialogue"
},
"120": {
&"character": "Lost File",
&"id": "120",
&"next_id": "121",
&"text": "I... I remember now.",
&"type": "dialogue"
},
"121": {
&"character": "Lost File",
&"id": "121",
&"next_id": "122",
&"text": "I was a letter. A love letter, never sent.",
&"type": "dialogue"
},
"122": {
&"character": "Lost File",
&"id": "122",
&"next_id": "123",
&"text": "Someone poured their heart into me.",
&"type": "dialogue"
},
"123": {
&"character": "Lost File",
&"id": "123",
&"next_id": "124",
&"text": "And my mother... Messy Directory...",
&"type": "dialogue"
},
"124": {
&"character": "Lost File",
&"id": "124",
&"next_id": "125",
&"text": "She created me with so much care.",
&"type": "dialogue"
},
"125": {
&"character": "Lost File",
&"id": "125",
&"next_id": "126",
&"text": "[The Lost File's fragments glow warmly]",
&"type": "dialogue"
},
"126": {
&"character": "Lost File",
&"id": "126",
&"next_id": "127",
&"text": "Thank you, user. You've given me peace.",
&"type": "dialogue"
},
"127": {
&"character": "Lost File",
&"id": "127",
&"next_id": "128",
&"text": "Tell her... tell Messy Directory... I love her.",
&"type": "dialogue"
},
"128": {
&"character": "Lost File",
&"id": "128",
&"next_id": "129",
&"text": "[The Lost File's fragments fade into a gentle light, ready to return home]",
&"type": "dialogue"
},
