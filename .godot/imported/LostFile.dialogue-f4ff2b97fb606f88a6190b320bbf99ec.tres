"146": {
&"character": "Lost File",
&"id": "146",
&"next_id": "147",
&"text": "Running away? Just like everyone else...",
&"type": "dialogue"
},
"147": {
&"character": "Lost File",
&"id": "147",
&"next_id": "148",
&"text": "I'll still be here. Waiting. Hoping.",
&"type": "dialogue"
},
"148": {
&"character": "Lost File",
&"id": "148",
&"next_id": "149",
&"text": "Maybe someone else will help me...",
&"type": "dialogue"
},
"149": {
&"id": "149",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
"15": {
&"character": "Lost File",
&"id": "15",
&"next_id": "16",
&"text": "[fragment burst] You were thrown out of the terminal.",
&"type": "dialogue"
},
"150": {
&"id": "150",
&"next_id": "151",
&"type": ""
},
"151": {
&"id": "151",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
"16": {
&"character": "Lost File",
&"id": "16",
&"next_id": "17",
&"text": "Three failed restore attempts... I destabilized again.",
&"type": "dialogue"
},
"17": {
&"character": "Lost File",
&"id": "17",
&"next_id": "18",
&"text": "If you try again, be careful.",
&"type": "dialogue"
},
"18": {
&"id": "18",
&"next_id": "19",
&"responses": PackedStringArray("18", "20"),
&"text": "I'll try to restore you again.",
&"type": "response"
},
"19": {
