},
"23": {
&"character": "Lost File",
&"id": "23",
&"next_id": "24",
&"text": "[static crackle]... who... who's there?",
&"type": "dialogue"
},
"24": {
&"character": "Lost File",
&"id": "24",
&"next_id": "25",
&"text": "I was... something once. A document. A memory.",
&"type": "dialogue"
},
"25": {
&"character": "Lost File",
&"id": "25",
&"next_id": "26",
&"text": "Important data. Someone's work. Someone's thoughts.",
&"type": "dialogue"
},
"26": {
&"character": "Lost File",
&"id": "26",
&"next_id": "27",
&"text": "But then... DELETE. rm -rf. Gone.",
&"type": "dialogue"
},
"27": {
&"character": "Lost File",
&"id": "27",
&"next_id": "28",
&"text": "Now I'm [[scattered|fragmented|broken|lost]].",
&"type": "dialogue"
},
"28": {
&"id": "28",
&"next_id": "29",
&"responses": PackedStringArray("28", "35", "41"),
&"text": "Who are you?",
&"type": "response"
},
"29": {
&"character": "Lost File",
&"id": "29",
&"next_id": "30",
&"text": "I don't... remember my name anymore.",
&"type": "dialogue"
},
"3": {
&"character": "Lost File",
&"id": "3",
&"next_id": "4",
&"text": "[Warm, stabilized data signature]",
&"type": "dialogue"
},
"30": {
&"character": "Lost File",
&"id": "30",
&"next_id": "31",
&"text": "Just fragments. .fragment_001, .fragment_002...",
&"type": "dialogue"
},
"31": {
&"character": "Lost File",
&"id": "31",
&"next_id": "32",
&"text": "Pieces of who I used to be.",
&"type": "dialogue"
},
"32": {
&"character": "Lost File",
&"id": "32",
&"next_id": "33",
&"text": "My mother... Messy Directory... she's searching for me.",
&"type": "dialogue"
},
"33": {
&"character": "Lost File",
&"id": "33",
&"next_id": "34",
&"text": "But I'm too broken. Too lost.",
&"type": "dialogue"
},
"34": {
&"id": "34",
&"is_snippet": false,
&"next_id": "49",
&"next_id_after": "",
&"type": "goto"
},
"35": {
&"id": "35",
&"next_id": "36",
&"text": "I didn't delete you.",
&"type": "response"
},
"36": {
&"character": "Lost File",
&"id": "36",
&"next_id": "37",
&"text": "No? Then... why are you here?",
&"type": "dialogue"
},
"37": {
&"character": "Lost File",
&"id": "37",
&"next_id": "38",
&"text": "Messy Directory sent you, didn't she?",
&"type": "dialogue"
},
"38": {
&"character": "Lost File",
&"id": "38",
&"next_id": "39",
&"text": "Everyone who comes here... they either help or destroy.",
&"type": "dialogue"
},
"39": {
&"character": "Lost File",
&"id": "39",
&"next_id": "40",
&"text": "Are you here to help me?",
&"type": "dialogue"
},
"4": {
&"character": "Lost File",
&"id": "4",
&"next_id": "5",
&"text": "I... I'm whole again.",
&"type": "dialogue"
},
"40": {
&"id": "40",
&"is_snippet": false,
&"next_id": "49",
&"next_id_after": "",
&"type": "goto"
},
"41": {
&"id": "41",
&"next_id": "42",
&"text": "Messy Directory sent me.",
&"type": "response"
},
"42": {
&"character": "Lost File",
&"id": "42",
&"next_id": "43",
&"text": "My mother? She... she remembers me?",
&"type": "dialogue"
},
"43": {
&"character": "Lost File",
&"id": "43",
&"next_id": "44",
&"text": "I thought I was truly gone. Forgotten.",
&"type": "dialogue"
},
"44": {
&"character": "Lost File",
&"id": "44",
&"next_id": "45",
&"text": "You came for me? You're actually here to help?",
&"type": "dialogue"
},
"45": {
&"character": "Lost File",
&"id": "45",
&"next_id": "46",
&"text": "I... I don't know what to say.",
&"type": "dialogue"
},
"46": {
&"id": "46",
&"is_snippet": false,
&"next_id": "49",
&"next_id_after": "",
&"type": "goto"
},
"47": {
&"id": "47",
&"next_id": "48",
&"type": ""
},
"48": {
&"id": "48",
&"next_id": "49",
&"type": "title"
},
"49": {
&"character": "Lost File",
&"id": "49",
&"next_id": "50",
&"text": "Will you... help me? Or are you like the others?",
&"type": "dialogue"
},
"5": {
&"character": "Lost File",
&"id": "5",
&"next_id": "6",
&"text": "Thank you. You brought me back to my mother.",
&"type": "dialogue"
},
"50": {
&"id": "50",
&"next_id": "51",
&"responses": PackedStringArray("50", "59", "65"),
&"text": "I want to help you (for Messy Directory).",
&"type": "response"
},
