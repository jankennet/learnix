&"id": "23",
&"next_id": "24",
&"text": "Teach me",
&"type": "response"
},
"24": {
&"character": "Elder Shell",
&"id": "24",
&"next_id": "25",
&"text": "Begin with understanding structure.",
&"type": "dialogue"
},
"25": {
&"character": "Elder Shell",
&"id": "25",
&"next_id": "26",
&"text": "The filesystem is organized like a tree - root (/) at the top.",
&"type": "dialogue"
},
"26": {
&"character": "Elder Shell",
&"id": "26",
&"next_id": "27",
&"text": "Directories: /home for users, /etc for configs, /bin for commands.",
&"type": "dialogue"
},
"27": {
&"character": "Elder Shell",
&"id": "27",
&"next_id": "28",
&"text": "Everything in Linux is a file or a process.",
&"type": "dialogue"
},
"28": {
&"character": "Elder Shell",
&"id": "28",
&"next_id": "29",
&"text": "Files have ownership: user, group, and permissions (rwx).",
&"type": "dialogue"
},
"29": {
&"character": "Elder Shell",
&"id": "29",
&"next_id": "30",
&"text": "Use 'ls -la' to see permissions. Know who can do what.",
&"type": "dialogue"
},
"3": {
&"id": "3",
&"next_id": "4",
&"responses": PackedStringArray("3"),
&"text": "Check my current status.",
&"type": "response"
},
"30": {
&"character": "Elder Shell",
&"id": "30",
&"next_id": "41",
&"text": "Speak to Messy Directory. She learned the price of carelessness.",
&"type": "dialogue"
},
"31": {
&"id": "31",
&"next_id": "32",
&"text": "What happened here?",
&"type": "response"
},
"32": {
&"character": "Elder Shell",
&"id": "32",
&"next_id": "33",
&"text": "Files were deleted in haste. Rm -rf is a dangerous command.",
&"type": "dialogue"
},
"33": {
&"character": "Elder Shell",
&"id": "33",
&"next_id": "34",
&"text": "Some files deserved removal. Others were innocents caught in the blast.",
&"type": "dialogue"
},
"34": {
&"character": "Elder Shell",
&"id": "34",
&"next_id": "41",
&"text": "The Lost File was a critical document. Someone thought it was junk.",
&"type": "dialogue"
},
"35": {
&"id": "35",
&"next_id": "36",
&"text": "Any advice?",
&"type": "response"
},
"36": {
&"character": "Elder Shell",
&"id": "36",
&"next_id": "37",
&"text": "Never run a command you do not understand.",
&"type": "dialogue"
},
"37": {
&"character": "Elder Shell",
&"id": "37",
&"next_id": "38",
&"text": "Always preview what you're deleting: 'ls' before 'rm'.",
&"type": "dialogue"
},
"38": {
&"character": "Elder Shell",
&"id": "38",
&"next_id": "39",
&"text": "Consider using trash systems instead of permanent deletion.",
&"type": "dialogue"
},
"39": {
&"character": "Elder Shell",
&"id": "39",
&"next_id": "40",
&"text": "And remember: root access is power. Use it wisely, or not at all.",
&"type": "dialogue"
},
