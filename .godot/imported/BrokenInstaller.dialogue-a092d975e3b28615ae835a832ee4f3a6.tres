"1": {
&"character": "Broken Installer",
&"id": "1",
&"next_id": "2",
&"text": "ERROR! ERROR!",
&"type": "dialogue"
},
"10": {
&"character": "Broken Installer",
&"id": "10",
&"next_id": "11",
&"text": "Each one a necessary foundation. Each one interconnected.",
&"type": "dialogue"
},
"11": {
&"character": "Broken Installer",
&"id": "11",
&"next_id": "30",
&"text": "It's called the dependency tree. Break a branch, everything falls.",
&"type": "dialogue"
},
"12": {
&"id": "12",
&"next_id": "13",
&"text": "What do you need?",
&"type": "response"
},
"13": {
&"character": "Broken Installer",
&"id": "13",
&"next_id": "14",
&"text": "A package manager! apt, pacman, dnf, zypper—ANY of them!",
&"type": "dialogue"
},
"14": {
&"character": "Broken Installer",
&"id": "14",
&"next_id": "15",
&"text": "They resolve dependencies automatically.",
&"type": "dialogue"
},
"15": {
&"character": "Broken Installer",
&"id": "15",
&"next_id": "16",
&"text": "apt install clears /etc/apt/sources.list",
&"type": "dialogue"
},
"16": {
&"character": "Broken Installer",
&"id": "16",
&"next_id": "17",
&"text": "pacman -Sy updates the mirror database first",
&"type": "dialogue"
},
"17": {
&"character": "Broken Installer",
&"id": "17",
&"next_id": "18",
&"text": "But first: you must know what each does!",
&"type": "dialogue"
},
"18": {
&"character": "Broken Installer",
&"id": "18",
&"next_id": "30",
&"text": "Update the system! Fetch the dependencies! FIX ME!",
&"type": "dialogue"
},
"19": {
&"id": "19",
&"next_id": "20",
&"text": "Ignore",
&"type": "response"
},
"2": {
&"character": "Broken Installer",
&"id": "2",
&"next_id": "3",
&"text": "Missing dependency! Missing libsupport.so!",
&"type": "dialogue"
},
"20": {
&"character": "Broken Installer",
&"id": "20",
&"next_id": "21",
&"text": "SYSTEM WILL BREAK FURTHER!!!",
&"type": "dialogue"
},
"21": {
&"character": "Broken Installer",
&"id": "21",
&"next_id": "30",
&"text": "Broken dependencies spread like corruption",
&"type": "dialogue"
},
"22": {
&"id": "22",
&"next_id": "23",
&"type": ""
},
"23": {
&"id": "23",
&"next_id": "24",
&"text": "Understand dependencies?",
&"type": "response"
},
"24": {
&"character": "Broken Installer",
&"id": "24",
&"next_id": "25",
&"text": "When you install software, it needs libraries.",
&"type": "dialogue"
},
"25": {
&"character": "Broken Installer",
&"id": "25",
&"next_id": "26",
&"text": "Libraries are code that other programs reuse.",
&"type": "dialogue"
},
"26": {
&"character": "Broken Installer",
&"id": "26",
&"next_id": "27",
&"text": "If a library is missing, nothing that depends on it can run!",
&"type": "dialogue"
},
"27": {
&"character": "Broken Installer",
&"id": "27",
&"next_id": "28",
&"text": "Package managers track versions and compatibility.",
&"type": "dialogue"
},
"28": {
&"character": "Broken Installer",
&"id": "28",
&"next_id": "30",
&"text": "They prevent the chaos that I am experiencing now.",
&"type": "dialogue"
},
"29": {
&"id": "29",
&"next_id": "30",
&"type": ""
},
"3": {
&"character": "Broken Installer",
&"id": "3",
&"next_id": "5",
&"text": "[hyperventilating in binary]",
&"type": "dialogue"
},
"30": {
&"character": "Broken Installer",
&"id": "30",
&"next_id": "31",
&"text": "Learn how to install packages properly.",
&"type": "dialogue"
},
"31": {
&"character": "Broken Installer",
&"id": "31",
&"next_id": "32",
&"text": "Understand dependency resolution.",
&"type": "dialogue"
},
"32": {
&"character": "Broken Installer",
&"id": "32",
&"next_id": "33",
&"text": "Then maybe… I can compile again. I can be whole.",
&"type": "dialogue"
},
