# Godot editor/runtime (local caches & generated data)
.godot/
!.godot/export_presets.cfg
!.godot/plugins/
!.godot/plugins/**

# Specific Godot editor cache files (already tracked in some clones)
.godot/scene_groups_cache.cfg
.godot/editor/editor_layout.cfg
.godot/editor/filesystem_update4

# Godot imported/generated resources
*.import
*.uid

# Godot exports / build outputs
export/
exported/
build/
bin/
obj/

# C# / Mono (if used)
.mono/
*.csproj
*.sln
*.user
*.userprefs
*.dll
*.pdb
*.mdb

# OS files (Windows / macOS)
Thumbs.db
desktop.ini
.DS_Store

# Editors / IDEs
.vscode/
.vs/
.idea/
*.iml

# Editor swap / backup files
*~
*.swp
*.tmp
*.cache
*.log
*.bak